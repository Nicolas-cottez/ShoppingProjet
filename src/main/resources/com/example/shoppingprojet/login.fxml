<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="451.0" prefWidth="596.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shoppingprojet.Controleur.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="15" styleClass="center-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <Label style="-fx-font-size:24px;" text="Connexion" />
            <TextField fx:id="emailField" promptText="Email" />
            <PasswordField fx:id="passwordField" promptText="Mot de passe" />
            <Label fx:id="errorLabel" textFill="red" />
            <HBox spacing="10">
                <Button alignment="CENTER" contentDisplay="CENTER" onAction="#goToRegister" text="Créer un compte">
               <HBox.margin>
                  <Insets left="70.0" />
               </HBox.margin></Button>
                <Button alignment="CENTER" onAction="#handleLogin" prefHeight="34.0" prefWidth="119.0" text="Connexion">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <padding>
                  <Insets top="50.0" />
               </padding>
               <HBox.margin>
                  <Insets left="100.0" />
               </HBox.margin></Button>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
